# Server
PORT=8080

# Token limit (context window cap)
MAX_CONTEXT_TOKENS=50000

# If true, the proxy will trim input content to fit the limit instead of rejecting.
TRUNCATE=false

# Optional: default upstream URL if you don't pass x-upstream-url header.
# Examples:
#   https://api.anthropic.com
#   https://api.openai.com
UPSTREAM_URL=
